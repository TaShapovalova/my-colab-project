{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1oeXsjj9R4wvlLOeGXy7QedTVa3RLVn1W","timestamp":1780580419058}],"authorship_tag":"ABX9TyM13LiVo6xpBUVKn7vhKfQf"},"kernelspec":{"name":"ir","display_name":"R"},"language_info":{"name":"R"}},"cells":[{"cell_type":"code","source":["# ==============================================================================\n","# ПОДГОТОВКА: Создаем виртуальные данные, так как оригинальный файл заблокирован\n","# ==============================================================================\n","set.seed(42)\n","n_samples <- 100\n","\n","# Создаем симуляцию оригинального датасета ТУСУР\n","# Целевая переменная Банкрот (0 или 1) и нужные по заданию факторы\n","df <- data.frame(\n","  Bankrupt. = sample(c(0, 1), n_samples, replace = TRUE),\n","  X16 = rnorm(n_samples), X18 = rnorm(n_samples), X19 = rnorm(n_samples),\n","  X37 = rnorm(n_samples), X42 = rnorm(n_samples), X46 = rnorm(n_samples),\n","  X50 = rnorm(n_samples), X57 = rnorm(n_samples), X74 = rnorm(n_samples),\n","  X81 = rnorm(n_samples)\n",")\n","\n","# ==============================================================================\n","# КЕЙС №1: РЕШЕНИЕ\n","# ==============================================================================\n","\n","# 1) Ознакомление и проверка пропусков (аналог df.isnull().sum())\n","print(\"Количество пропусков в данных:\")\n","print(colSums(is.na(df)))\n","\n","# 2) Разделение на обучающую и тестовую выборки (70% на 30%)\n","train_idx <- sample(1:nrow(df), 0.7 * nrow(df))\n","train_data <- df[train_idx, ]\n","test_data  <- df[-train_idx, ]\n","\n","# 3) Классификация логистической регрессией (функция glm с family=\"binomial\")\n","model_logit <- glm(Bankrupt. ~ X16 + X18 + X19 + X37 + X42 + X46 + X50 + X57 + X74 + X81,\n","                   data = train_data,\n","                   family = \"binomial\")\n","\n","print(\"Сводка логистической регрессии:\")\n","print(summary(model_logit))\n","\n","# Прогнозирование вероятности на тестовой выборке\n","test_data$prob <- predict(model_logit, newdata = test_data, type = \"response\")\n","\n","# Прогноз для двух произвольных объектов (берём первые два из теста)\n","two_objects <- test_data[1:2, ]\n","print(\"Прогноз вероятности банкротства для двух объектов:\")\n","print(two_objects$prob)\n","\n","# 4) Классификация методом k-ближайших соседей (KNN)\n","# Устанавливаем и подключаем нужные библиотеки R\n","install.packages(c(\"class\", \"gmodels\"), quiet = TRUE)\n","library(class)\n","library(gmodels)\n","\n","# Выделяем признаки для KNN (убираем целевую переменную из тренировочных векторов)\n","train_x <- train_data[, -1]\n","test_x  <- test_data[, -c(1, ncol(test_data))] # убираем колонку ответа и prob\n","train_y <- train_data$Bankrupt.\n","test_y  <- test_data$Bankrupt.\n","\n","# Запуск KNN (k = 3)\n","knn_pred <- knn(train = train_x, test = test_x, cl = train_y, k = 3)\n","\n","# Построение матрицы неточностей (CrossTable из пакета gmodels)\n","print(\"Матрица неточностей для KNN:\")\n","CrossTable(x = test_y, y = knn_pred, prop.chisq = FALSE)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"EHaGCXFNPrzx","executionInfo":{"status":"ok","timestamp":1780586855985,"user_tz":-300,"elapsed":13730,"user":{"displayName":"Ta Sha","userId":"13567804846267301364"}},"outputId":"7369b2ae-0942-4839-c838-1ff1fa60920e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["[1] \"Количество пропусков в данных:\"\n","Bankrupt.       X16       X18       X19       X37       X42       X46       X50 \n","        0         0         0         0         0         0         0         0 \n","      X57       X74       X81 \n","        0         0         0 \n","[1] \"Сводка логистической регрессии:\"\n","\n","Call:\n","glm(formula = Bankrupt. ~ X16 + X18 + X19 + X37 + X42 + X46 + \n","    X50 + X57 + X74 + X81, family = \"binomial\", data = train_data)\n","\n","Coefficients:\n","             Estimate Std